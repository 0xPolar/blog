---
import books from '../../../public/books.json';
import type { Book } from './types';

interface Props {
  showReadingProgress?: boolean;
}

const { showReadingProgress = false } = Astro.props;
const shelfBooks = books as Book[];

function getAuthor(book: Book): string {
  if (book.authors && book.authors.length > 0) {
    const meaningful = book.authors.filter(a => !/^\d{4}(-\d{4})?$/.test(a));
    if (meaningful.length > 0) return [...meaningful].reverse().join(' ');
  }
  return book.series_name;
}

function cleanTitle(title: string): string {
  return title
    .replace(/_+/g, ' ')
    .replace(/\s+/g, ' ')
    .replace(/\s*\(\d{4}\)\s*$/, '')
    .trim();
}

const booksJson = JSON.stringify(shelfBooks).replace(/</g, '\\u003c');
---

{shelfBooks.length > 0 && (
  <section class="book-shelf" data-book-shelf data-show-progress={String(showReadingProgress)}>
    <h2>Currently Reading</h2>
    <div class="book-list">
      {shelfBooks.map((book, index) => {
        const title = cleanTitle(book.title);
        const author = getAuthor(book);

        return (
          <button class="book-card" type="button" data-book-index={index} aria-label={`Open ${title}`}>
            <div class="book-cover">
              <img src={book.thumbnail} alt={title} loading="lazy" />
              {showReadingProgress && (
                <div class="book-progress-track">
                  <div class="book-progress-fill" style={`width: ${book.progress_pct}%`} />
                </div>
              )}
            </div>
            <div class="book-meta">
              <p class="book-title">{title}</p>
              <p class="book-author">{author}</p>
            </div>
          </button>
        );
      })}
    </div>

    <div class="book-modal" data-book-modal hidden>
      <div class="book-modal-backdrop" data-book-close></div>
      <div class="book-modal-panel" role="dialog" aria-modal="true" aria-labelledby="book-modal-title">
        <button class="book-modal-close" type="button" aria-label="Close" data-book-close>&times;</button>
        <div class="book-modal-cover">
          <img data-book-modal-cover alt="" />
        </div>
        <div class="book-modal-content">
          <h3 id="book-modal-title" data-book-modal-title></h3>
          <p class="book-modal-author" data-book-modal-author></p>
          <div class="book-modal-progress" data-book-modal-progress hidden>
            <div class="book-modal-progress-label">
              <span data-book-modal-pages></span>
              <span data-book-modal-percent></span>
            </div>
            <div class="book-modal-progress-track">
              <div class="book-modal-progress-fill" data-book-modal-progress-fill></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script type="application/json" data-book-data set:html={booksJson}></script>
  </section>
)}

<script>
  const cleanTitle = (title) =>
    title
      .replace(/_+/g, ' ')
      .replace(/\s+/g, ' ')
      .replace(/\s*\(\d{4}\)\s*$/, '')
      .trim();

  const getAuthor = (book) => {
    if (book.authors && book.authors.length > 0) {
      const meaningful = book.authors.filter(author => !/^\d{4}(-\d{4})?$/.test(author));
      if (meaningful.length > 0) return [...meaningful].reverse().join(' ');
    }
    return book.series_name;
  };

  document.querySelectorAll('[data-book-shelf]').forEach((shelf) => {
    const data = shelf.querySelector('[data-book-data]');
    const modal = shelf.querySelector('[data-book-modal]');
    if (!data || !modal) return;

    const books = JSON.parse(data.textContent || '[]');
    const showProgress = shelf.getAttribute('data-show-progress') === 'true';
    const cover = modal.querySelector('[data-book-modal-cover]');
    const title = modal.querySelector('[data-book-modal-title]');
    const author = modal.querySelector('[data-book-modal-author]');
    const progress = modal.querySelector('[data-book-modal-progress]');
    const pages = modal.querySelector('[data-book-modal-pages]');
    const percent = modal.querySelector('[data-book-modal-percent]');
    const progressFill = modal.querySelector('[data-book-modal-progress-fill]');

    const closeModal = () => {
      modal.setAttribute('hidden', '');
      document.body.style.overflow = '';
    };

    const openModal = (book) => {
      const cleanedTitle = cleanTitle(book.title);
      const hasRelease = !book.release_date.startsWith('0001');
      const releaseYear = hasRelease ? new Date(book.release_date).getFullYear() : null;

      cover.src = book.thumbnail;
      cover.alt = cleanedTitle;
      title.textContent = cleanedTitle;
      author.textContent = `${getAuthor(book)}${releaseYear ? ` · ${releaseYear}` : ''}`;
      pages.textContent = `${book.pages_read} of ${book.pages} pages`;
      percent.textContent = `${Math.round(book.progress_pct)}%`;
      progressFill.style.width = `${book.progress_pct}%`;
      progress.hidden = !showProgress;

      modal.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
    };

    shelf.querySelectorAll('[data-book-index]').forEach((button) => {
      button.addEventListener('click', () => {
        const book = books[Number(button.getAttribute('data-book-index'))];
        if (book) openModal(book);
      });
    });

    modal.querySelectorAll('[data-book-close]').forEach((button) => {
      button.addEventListener('click', closeModal);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !modal.hasAttribute('hidden')) closeModal();
    });
  });
</script>

<style>
  .book-shelf {
    margin-top: 32px;
  }

  .book-shelf h2 {
    color: var(--primary);
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .book-list {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    padding-bottom: 12px;
    scrollbar-width: thin;
    scrollbar-color: var(--tertiary) transparent;
  }

  .book-card {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
    flex-shrink: 0;
    width: 140px;
  }

  .book-cover {
    position: relative;
    aspect-ratio: 2 / 3;
    overflow: hidden;
    border-radius: 6px;
    border: 1px solid var(--border);
  }

  .book-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.2s ease;
  }

  .book-card:hover .book-cover img,
  .book-card:focus-visible .book-cover img {
    transform: scale(1.04);
  }

  .book-progress-track {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: rgba(128, 128, 128, 0.35);
  }

  .book-progress-fill {
    height: 100%;
    background: #3b82f6;
  }

  .book-meta {
    margin-top: 8px;
  }

  .book-title {
    color: var(--primary);
    font-size: 13px;
    font-weight: 500;
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .book-author {
    color: var(--secondary);
    font-size: 12px;
    margin: 4px 0 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .book-modal[hidden] {
    display: none;
  }

  .book-modal {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }

  .book-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(2px);
  }

  .book-modal-panel {
    position: relative;
    max-width: 440px;
    width: 100%;
    border-radius: 10px;
    padding: 20px;
    display: flex;
    gap: 16px;
    background: var(--entry);
    border: 1px solid var(--border);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  }

  .book-modal-close {
    position: absolute;
    top: 10px;
    right: 14px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 20px;
    line-height: 1;
    color: var(--secondary);
    padding: 2px 4px;
  }

  .book-modal-cover {
    flex-shrink: 0;
    width: 96px;
    aspect-ratio: 2 / 3;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .book-modal-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .book-modal-content {
    flex: 1;
    min-width: 0;
  }

  .book-modal-content h3 {
    color: var(--primary);
    font-size: 15px;
    font-weight: 600;
    line-height: 1.4;
    margin: 0 0 4px;
  }

  .book-modal-author {
    color: var(--secondary);
    font-size: 13px;
    margin: 0 0 14px;
  }

  .book-modal-progress {
    margin-bottom: 12px;
  }

  .book-modal-progress-label {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--secondary);
    margin-bottom: 5px;
  }

  .book-modal-progress-track {
    height: 5px;
    border-radius: 99px;
    overflow: hidden;
    background: var(--tertiary);
  }

  .book-modal-progress-fill {
    height: 100%;
    border-radius: 99px;
    background: #3b82f6;
  }
</style>
