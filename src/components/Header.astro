---
import { SITE_TITLE, NAV } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="header">
	<nav class="nav">
		<div class="logo">
			<a href="/">{SITE_TITLE}</a>
		</div>
		<ul class="menu">
			{NAV.map((item) => (
				<li><HeaderLink href={item.href}>{item.label}</HeaderLink></li>
			))}
			<li><ThemeToggle /></li>
		</ul>
	</nav>
</header>

<style>
	.header {
		background: var(--theme);
		border-bottom: 1px solid var(--border);
	}
	.nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: center;
		max-width: calc(var(--nav-width) + var(--gap) * 2);
		margin: auto;
		min-height: var(--header-height);
		line-height: var(--header-height);
		padding: 0 var(--gap);
		column-gap: var(--gap);
	}
	.logo a {
		display: inline-flex;
		align-items: center;
		font-size: 24px;
		font-weight: 700;
		color: var(--primary);
		text-decoration: none;
	}
	.menu {
		display: flex;
		list-style: none;
		gap: var(--gap);
		margin: 0;
		padding: 0;
		overflow-x: auto;
		white-space: nowrap;
		align-items: center;
	}
	.menu :global(a) {
		font-size: 16px;
		color: var(--primary);
	}
</style>
