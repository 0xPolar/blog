---
import { SITE_TITLE, SOCIALS } from '../consts';
const today = new Date();
---

<footer class="footer">
	<span>&copy; {today.getFullYear()} {SITE_TITLE}</span>
	{SOCIALS.map((s) => (
		<>
			<span class="sep"> · </span>
			<a href={s.url} target={s.url.startsWith('http') ? '_blank' : undefined} rel={s.url.startsWith('http') ? 'noopener noreferrer' : undefined}>{s.label}</a>
		</>
	))}
</footer>

<style>
	.footer {
		max-width: calc(var(--main-width) + var(--gap) * 2);
		margin: auto;
		padding: 18px var(--gap);
		text-align: center;
		font-size: 12px;
		line-height: 24px;
		color: var(--secondary);
	}
	.footer a {
		color: inherit;
		text-decoration: underline;
		text-underline-offset: 0.25rem;
	}
	.footer a:hover {
		color: var(--primary);
	}
</style>
